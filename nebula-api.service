# File path: /etc/systemd/system/nebula-api.service
# sudo systemctl daemon-reload
# sudo systemctl start nebula-api
# sudo systemctl enable nebula-api
# sudo systemctl status nebula-api
[Unit]
Description=Nebula API Service
After=network.target

[Service]
User=ubuntu  # 注意修改用户名
WorkingDirectory=/path/to/nebula-api  # 注意修改路径
ExecStart=/path/to/nebula-api/nebula-api --port 3000 --log-dir /path/to/nebula-api/logs  # 注意修改路径和端口号
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
