# Copy this file to .env.prod and fill in your values.
# NEVER commit .env.prod to git!

# PostgreSQL
POSTGRES_USER=newapi
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=newapi

# Session secret — used to sign admin dashboard cookies (client-side session).
# Must be a fixed value, otherwise all users get logged out on container restart.
# Generate with: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_TO_A_RANDOM_STRING

# Data directories — all persistent data, each service gets its own path.
# On Tencent Cloud, mount CBS to /data and use /data/<service> paths.
DATA_DIR_NEWAPI=/data/new-api
DATA_DIR_LOGS=/data/logs
DATA_DIR_POSTGRES=/data/postgres
DATA_DIR_REDIS=/data/redis
